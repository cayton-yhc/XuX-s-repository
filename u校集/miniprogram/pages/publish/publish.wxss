.publish-page {
  padding-top: calc(env(safe-area-inset-top) + 100rpx);
  background: radial-gradient(circle at 85% 8%, rgba(250, 226, 168, 0.24) 0%, transparent 28%),
    radial-gradient(circle at 15% 14%, rgba(198, 229, 190, 0.2) 0%, transparent 30%);
}

.publish-card {
  padding: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(251, 254, 248, 0.96) 100%);
  border: 2rpx solid rgba(231, 239, 220, 0.9);
}

.login-gate {
  padding: 34rpx 30rpx;
  border: 2rpx solid rgba(231, 239, 220, 0.9);
}

.gate-btn {
  margin-top: 28rpx;
}

.block {
  margin-top: 30rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  color: #314530;
}

.sub-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7b8775;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 18rpx;
}

.image-item,
.upload-entry {
  width: 206rpx;
  height: 206rpx;
  border-radius: 24rpx;
  position: relative;
}

.preview {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: #edf3e7;
}

.remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.48);
  color: #fff;
  text-align: center;
  line-height: 42rpx;
}

.upload-entry {
  background: #fbfcf8;
  border: 2rpx dashed #d9e8d4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6d7b67;
}

.upload-plus {
  font-size: 54rpx;
  line-height: 1;
}

.upload-text {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.ai-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5f7f57;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.submit-btn {
  margin-top: 34rpx;
}
